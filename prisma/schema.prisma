generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  role      String   @default("USER")
  balance   Float    @default(0.0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Lists        List[]
  Contacts     Contact[]
  Campaigns    Campaign[]
  MessageLogs  MessageLog[]
  Links        Link[]
  SmsTemplates SmsTemplate[]
}

model SmsTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model List {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User          @relation(fields: [userId], references:[id], onDelete: Cascade)
  Contacts  ListContact[]
  Campaigns Campaign[]
}

model Contact {
  id        String   @id @default(uuid())
  userId    String
  phone     String
  firstName String?
  lastName  String?
  city      String?
  isOptOut  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User          @relation(fields:[userId], references: [id], onDelete: Cascade)
  Lists       ListContact[]
  MessageLogs MessageLog[]
  LinkClick   LinkClick[]

  @@unique([userId, phone])
}

model ListContact {
  listId    String
  contactId String
  createdAt DateTime @default(now())

  list    List    @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([listId, contactId])
}

model Campaign {
  id          String    @id @default(uuid())
  userId      String
  name        String
  senderId    String?
  messageBody String
  status      String
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  listId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  MessageLogs MessageLog[]
}

model MessageLog {
  id         String   @id @default(uuid())
  userId     String
  campaignId String?
  contactId  String
  status     String
  cost       Float    @default(0.07)
  error      String?
  sentAt     DateTime @default(now())

  user     User      @relation(fields:[userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields:[campaignId], references: [id], onDelete: SetNull)
  contact  Contact   @relation(fields:[contactId], references: [id], onDelete: Cascade)
}

model Link {
  id          String   @id @default(uuid())
  userId      String
  code        String   @unique
  originalUrl String
  createdAt   DateTime @default(now())

  user   User        @relation(fields:[userId], references: [id], onDelete: Cascade)
  Clicks LinkClick[]
}

model LinkClick {
  id        String   @id @default(uuid())
  linkId    String
  contactId String?
  ipAddress String?
  userAgent String?
  clickedAt DateTime @default(now())

  link    Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
}

model Setting {
  key   String @id
  value String
}

model SmsApi {
  id        String   @id @default(uuid())
  name      String
  url       String
  headers   String
  payload   String
  isActive  Boolean  @default(true)
  failCount Int      @default(0)
  lastError String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}